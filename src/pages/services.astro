---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | Verse & Vow" description="Live music, DJ services, photography, videography, catering coordination, and custom event planning. Professional entertainment services for weddings and celebrations worldwide.">
  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container text-center">
      <p class="page-hero-pre">Our Services</p>
      <h1>What We Offer</h1>
      <p class="page-hero-sub">
        Music · Photo & Video · Catering · Event Planning
      </p>
    </div>
  </section>

  <!-- ===== MUSIC ===== -->
  <section class="section" id="music">
    <div class="container">
      <div class="service-block">
        <div class="service-content">
          <h2>Music</h2>
          <span class="ornament"></span>
          <p class="lead-text">
            Here's what makes us different: the same artist who performs your
            acoustic ceremony transitions seamlessly into DJ mode for your
            reception. No coordination headaches. No energy gaps. One person
            who understands the entire emotional arc of your day.
          </p>
          <div class="service-split">
            <div class="service-half">
              <h4>🎸 Live Acoustic</h4>
              <ul class="service-features">
                <li>Live guitar and vocal performances</li>
                <li>Custom song arrangements</li>
                <li>Ceremony processional & recessional</li>
                <li>Cocktail hour ambiance</li>
              </ul>
            </div>
            <div class="service-half">
              <h4>🎧 DJ & Production</h4>
              <ul class="service-features">
                <li>Curated playlists for your taste</li>
                <li>Seamless professional mixing</li>
                <li>MC services & announcements</li>
                <li>Full PA & lighting systems</li>
              </ul>
            </div>
          </div>
          <p class="service-highlight">
            With a founder who holds a professorship in Recording Arts,
            studio-quality sound isn't a luxury — it's the baseline.
          </p>
        </div>
        <div class="service-visual">
          <img src="/images/music-guitar.jpg" alt="Live acoustic guitar performance at wedding ceremony" />
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== PHOTO/VIDEO ===== -->
  <section class="section section-cream" id="photo-video">
    <div class="container">
      <div class="service-block reverse">
        <div class="service-content">
          <h2>Photo & Video</h2>
          <span class="ornament"></span>
          <p class="lead-text">
            Your celebration deserves to be captured with intention and artistry.
            We don't just document — we craft visual stories that bring back the
            emotion, energy, and beauty of your day for years to come.
          </p>
          <ul class="service-features large">
            <li>Cinematic wedding films with professional color grading</li>
            <li>Documentary and editorial photography styles</li>
            <li>Drone coverage for breathtaking aerials</li>
            <li>Same-day highlight edits for reception screenings</li>
            <li>Multi-camera and multi-photographer coverage</li>
            <li>Premium albums and archival-quality prints</li>
          </ul>
          <p class="service-highlight">
            From intimate first looks to grand reception entrances — we see the
            creative potential in every scene.
          </p>
        </div>
        <div class="service-visual">
          <img src="/images/photo-video.jpg" alt="Professional wedding photography and videography" />
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== CATERING ===== -->
  <section class="section" id="catering">
    <div class="container">
      <div class="service-block">
        <div class="service-content">
          <h2>Catering</h2>
          <span class="ornament"></span>
          <p class="lead-text">
            Food is memory. It's tradition. It's how families come together.
            We connect you with exceptional caterers who understand that cuisine
            is a celebration in itself.
          </p>
          <ul class="service-features large">
            <li>Vetted catering partner recommendations</li>
            <li>Menu planning and tasting coordination</li>
            <li>Dietary accommodations across cuisines</li>
            <li>Service style consultation (plated, buffet, family-style)</li>
            <li>Bar and beverage program design</li>
            <li>Day-of catering logistics management</li>
          </ul>
          <p class="service-highlight">
            Whether it's a traditional Indian feast, an elegant French dinner, or
            a vibrant fusion menu — we know who to call.
          </p>
        </div>
        <div class="service-visual">
          <img src="/images/catering-food.jpg" alt="Elegant wedding catering and cuisine" />
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== CUSTOM EVENT PLANNING ===== -->
  <section class="section section-cream" id="planning">
    <div class="container">
      <div class="service-block reverse">
        <div class="service-content">
          <h2>Custom Event Planning</h2>
          <span class="ornament"></span>
          <p class="lead-text">
            Every culture celebrates love differently. From Hindu mandaps to
            Christian altars, Jewish chuppahs to Muslim nikkahs — we've helped
            design weddings across traditions and continents.
          </p>
          <ul class="service-features large">
            <li>Full-service wedding planning from engagement to send-off</li>
            <li>Day-of coordination and timeline management</li>
            <li>Cultural ceremony expertise across traditions</li>
            <li>Multi-day event coordination</li>
            <li>Vendor sourcing and management</li>
            <li>Decor and lighting design consultation</li>
            <li>Destination wedding coordination</li>
          </ul>
          <p class="service-highlight">
            <strong>Worldwide experience:</strong> We've designed celebrations
            in India, the Caribbean, across the United States, and beyond. Your
            vision isn't limited by geography.
          </p>
        </div>
        <div class="service-visual">
          <img src="/images/event-planning.jpg" alt="Custom wedding event design and planning" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section-dark cta-section">
    <div class="container text-center">
      <h2>Ready to Plan Your Celebration?</h2>
      <span class="ornament" style="margin: 1rem auto; background: linear-gradient(90deg, transparent, var(--gold-light), transparent);"></span>
      <p class="cta-text">
        Tell us about your vision. Whether you need one service or all four,
        we'll create a custom package that brings your celebration to life.
      </p>
      <a href="/contact" class="btn btn-primary">Start the Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: clamp(6rem, 10vw, 8rem) 0 clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(160deg, var(--slate-deep), var(--slate));
    color: var(--cream);
  }

  .page-hero-pre {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .page-hero-sub {
    font-size: 1.35rem;
    max-width: 550px;
    margin: 0 auto;
    opacity: 0.9;
    line-height: 1.8;
  }

  /* Tighter section spacing */
  .section {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  /* ===== SERVICE BLOCKS ===== */
  .service-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .service-block.reverse {
    direction: rtl;
  }

  .service-block.reverse > * {
    direction: ltr;
  }

  .service-content h2 {
    margin-bottom: 0.5rem;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
  }

  .service-content .ornament {
    display: block;
    width: 60px;
    height: 3px;
    background: var(--gold);
    margin: 1rem 0 1.5rem;
  }

  .lead-text {
    font-size: 1.3rem;
    margin-bottom: 2rem;
    color: var(--charcoal);
    line-height: 1.8;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .service-features.large li {
    font-size: 1.1rem;
  }

  .service-features li {
    position: relative;
    padding-left: 1.75rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--charcoal-light);
  }

  .service-features li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.8rem;
    top: 0.35rem;
  }

  .service-highlight {
    background: linear-gradient(135deg, #fdf8f0, var(--cream-dark));
    padding: 1.5rem;
    border-left: 4px solid var(--gold);
    font-size: 1.1rem;
    margin-top: 1.5rem;
    line-height: 1.7;
  }

  .service-highlight strong {
    color: var(--slate-deep);
  }

  /* Service split layout */
  .service-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin: 2rem 0;
  }

  .service-half h4 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--slate-deep);
    margin-bottom: 1rem;
  }

  /* Service visual images */
  .service-visual {
    width: 100%;
    height: 450px;
    overflow: hidden;
    border: 2px solid rgba(201, 168, 76, 0.2);
  }

  .service-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .service-block:hover .service-visual img {
    transform: scale(1.03);
  }

  /* ===== CTA ===== */
  .cta-section h2 {
    color: var(--gold-light);
  }

  .cta-text {
    font-size: 1.3rem;
    max-width: 600px;
    margin: 0 auto 2.5rem;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .service-block,
    .service-block.reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      direction: ltr;
    }

    .service-split {
      grid-template-columns: 1fr;
    }

    .service-visual {
      height: 280px;
    }

    .lead-text {
      font-size: 1.15rem;
    }

    .page-hero-sub {
      font-size: 1.15rem;
    }
  }
</style>
