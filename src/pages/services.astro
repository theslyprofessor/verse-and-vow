---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | Verse & Vow" description="Live music, DJ services, photography, videography, audio production, and event planning. Professional entertainment and media services for weddings and celebrations.">
  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container text-center">
      <p class="page-hero-pre">Our Services</p>
      <h1>Entertainment. Media. Events.</h1>
      <p class="page-hero-sub">
        From the first acoustic note of your ceremony to the final frame of
        your wedding film — we bring professional artistry to every moment.
      </p>
    </div>
  </section>

  <!-- ===== LIVE MUSIC & DJ ===== -->
  <section class="section" id="music">
    <div class="container">
      <div class="service-block">
        <div class="service-content">
          <span class="service-number">01</span>
          <h2>Live Music & DJ Services</h2>
          <span class="ornament"></span>
          <p>
            Here's what makes us different: the same artist who performs your
            acoustic ceremony transitions seamlessly into DJ mode for your
            reception. No coordination headaches. No energy gaps. Just one
            person who understands the flow of your entire day.
          </p>
          <div class="service-split">
            <div class="service-half">
              <h4>🎸 Acoustic Ceremony</h4>
              <ul class="service-features">
                <li>Live guitar and vocal performances</li>
                <li>Custom song arrangements for processional & recessional</li>
                <li>Instrumental covers of your favorite songs</li>
                <li>Readings accompaniment and background music</li>
                <li>Ceremony sound system included</li>
              </ul>
            </div>
            <div class="service-half">
              <h4>🎧 DJ Reception</h4>
              <ul class="service-features">
                <li>Curated playlists tailored to your taste</li>
                <li>Seamless mixing and professional transitions</li>
                <li>MC services and announcements</li>
                <li>Dance floor lighting coordination</li>
                <li>Full PA system and professional equipment</li>
              </ul>
            </div>
          </div>
          <p class="service-note">
            <strong>Why this matters:</strong> Most couples hire separate vendors
            for ceremony music and reception DJ. That means coordinating schedules,
            managing handoffs, and hoping the energy translates. With Verse & Vow,
            it's all one cohesive experience.
          </p>
        </div>
        <div class="service-visual placeholder-block">
          <span>Live Performance</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== PHOTOGRAPHY & VIDEOGRAPHY ===== -->
  <section class="section section-cream" id="photo-video">
    <div class="container">
      <div class="service-block reverse">
        <div class="service-content">
          <span class="service-number">02</span>
          <h2>Photography & Videography</h2>
          <span class="ornament"></span>
          <p>
            Your celebration deserves to be captured with intention and artistry.
            We don't just document what happens — we craft visual stories that
            bring back the emotion, energy, and beauty of your day.
          </p>
          <ul class="service-features">
            <li>Cinematic wedding films with professional color grading</li>
            <li>Documentary and editorial photography styles</li>
            <li>Drone coverage for breathtaking aerial perspectives</li>
            <li>Same-day highlight edits for reception screenings</li>
            <li>Multi-photographer teams for simultaneous coverage</li>
            <li>Bridal portraits and pre-wedding creative sessions</li>
            <li>Premium albums and archival-quality prints</li>
            <li>Digital galleries with full resolution downloads</li>
          </ul>
          <p class="service-note">
            <strong>Creative opportunities:</strong> From intimate first looks
            to grand reception entrances, from candid moments to carefully
            composed portraits — we see the potential in every scene.
          </p>
        </div>
        <div class="service-visual placeholder-block">
          <span>Photo & Video Portfolio</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== AUDIO PRODUCTION ===== -->
  <section class="section" id="audio">
    <div class="container">
      <div class="service-block">
        <div class="service-content">
          <span class="service-number">03</span>
          <h2>Audio Production & Sound Design</h2>
          <span class="ornament"></span>
          <p>
            Most event vendors treat audio as an afterthought. We treat it as
            the foundation. When your founder is a Recording Arts professor,
            studio-quality sound isn't a luxury — it's the standard.
          </p>
          <ul class="service-features">
            <li>Professional wireless microphone systems</li>
            <li>Crystal-clear ceremony audio capture</li>
            <li>Live sound mixing and reinforcement</li>
            <li>Acoustic analysis and venue-specific setup</li>
            <li>High-fidelity playback systems</li>
            <li>Audio for wedding films captured with professional gear</li>
            <li>Custom soundtracks and audio editing</li>
          </ul>
          <p class="service-note">
            <strong>The difference you'll hear:</strong> Vows that every guest
            can actually understand. Toasts captured clearly. Reception music
            that sounds rich, not muddy. This is what professional audio means.
          </p>
        </div>
        <div class="service-visual placeholder-block">
          <span>Professional Audio</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== EVENT PLANNING ===== -->
  <section class="section section-cream" id="planning">
    <div class="container">
      <div class="service-block reverse">
        <div class="service-content">
          <span class="service-number">04</span>
          <h2>Event Planning & Coordination</h2>
          <span class="ornament"></span>
          <p>
            Whether you need full-service planning or day-of coordination,
            we bring organization, cultural fluency, and calm professionalism
            to every celebration.
          </p>
          <ul class="service-features">
            <li>Full-service wedding planning from engagement to send-off</li>
            <li>Day-of coordination and timeline management</li>
            <li>Vendor sourcing and contract negotiation</li>
            <li>Cultural ceremony expertise across traditions</li>
            <li>Multi-day event coordination</li>
            <li>Rehearsal management</li>
            <li>Guest management and RSVP tracking</li>
            <li>Budget planning and tracking</li>
          </ul>
          <p class="service-note">
            <strong>Cultural fluency:</strong> We've coordinated Hindu ceremonies,
            Christian weddings, Jewish celebrations, Muslim nikkahs, and fusion
            events. Every tradition has its own rhythm — we understand them.
          </p>
        </div>
        <div class="service-visual placeholder-block">
          <span>Event Coordination</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== DECOR & LIGHTING ===== -->
  <section class="section" id="decor">
    <div class="container">
      <div class="service-block">
        <div class="service-content">
          <span class="service-number">05</span>
          <h2>Decor & Lighting Design</h2>
          <span class="ornament"></span>
          <p>
            Lighting sets the mood. Decor tells the story. We design environments
            that photograph beautifully and feel magical to experience.
          </p>
          <ul class="service-features">
            <li>Ambient and architectural lighting design</li>
            <li>Dance floor and stage lighting</li>
            <li>Uplighting and color washes</li>
            <li>String lights and romantic installations</li>
            <li>Stage and backdrop design</li>
            <li>Venue transformation and styling</li>
            <li>Coordination with florists and decorators</li>
          </ul>
        </div>
        <div class="service-visual placeholder-block">
          <span>Lighting Design</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== CATERING COORDINATION ===== -->
  <section class="section section-cream" id="catering">
    <div class="container">
      <div class="service-block reverse">
        <div class="service-content">
          <span class="service-number">06</span>
          <h2>Catering Coordination</h2>
          <span class="ornament"></span>
          <p>
            We connect you with trusted caterers who can deliver exceptional
            cuisine for any style of celebration. From intimate dinners to
            grand banquets, we coordinate the details.
          </p>
          <ul class="service-features">
            <li>Vetted catering partner recommendations</li>
            <li>Menu planning assistance</li>
            <li>Dietary accommodation coordination</li>
            <li>Service style consultation (plated, buffet, family-style)</li>
            <li>Bar and beverage planning</li>
            <li>Day-of catering logistics management</li>
          </ul>
        </div>
        <div class="service-visual placeholder-block">
          <span>Catering Partners</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PACKAGES ===== -->
  <section class="section section-dark">
    <div class="container">
      <div class="section-header">
        <h2>How We Work Together</h2>
        <span class="ornament"></span>
        <p>Every celebration is unique. We build custom packages around your needs.</p>
      </div>

      <div class="grid-3 package-grid">
        <div class="package-card">
          <h3>Entertainment Focus</h3>
          <p class="package-desc">
            Live acoustic ceremony + DJ reception + professional sound
          </p>
          <ul class="package-features">
            <li>Acoustic ceremony performance</li>
            <li>DJ services for reception</li>
            <li>Professional PA system</li>
            <li>MC services</li>
            <li>Dance floor lighting</li>
          </ul>
          <p class="package-ideal">Ideal for couples who want seamless music</p>
        </div>

        <div class="package-card featured">
          <span class="package-badge">Most Popular</span>
          <h3>Full Media Package</h3>
          <p class="package-desc">
            Entertainment + Photography + Videography
          </p>
          <ul class="package-features">
            <li>Everything in Entertainment Focus</li>
            <li>Full-day photography coverage</li>
            <li>Cinematic wedding film</li>
            <li>Drone coverage</li>
            <li>Same-day highlights</li>
            <li>Premium album included</li>
          </ul>
          <p class="package-ideal">Ideal for couples who want it all</p>
        </div>

        <div class="package-card">
          <h3>À La Carte</h3>
          <p class="package-desc">
            Pick exactly what you need
          </p>
          <ul class="package-features">
            <li>Individual service pricing</li>
            <li>Flexible combinations</li>
            <li>Add-ons available</li>
            <li>Custom packages</li>
            <li>Consultation included</li>
          </ul>
          <p class="package-ideal">Ideal for couples with specific needs</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Ready to Plan Your Celebration?</h2>
      <span class="ornament" style="margin: 1rem auto;"></span>
      <p style="max-width: 600px; margin: 0 auto 2.5rem; font-size: 1.15rem;">
        Tell us about your vision. We'll create a custom package that
        brings together exactly what you need.
      </p>
      <a href="/contact" class="btn btn-primary">Get a Free Quote</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: clamp(8rem, 15vw, 12rem) 0 clamp(4rem, 8vw, 6rem);
    background: linear-gradient(160deg, var(--slate-deep), var(--slate));
    color: var(--cream);
  }

  .page-hero-pre {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .page-hero-sub {
    font-size: 1.15rem;
    max-width: 550px;
    margin: 0 auto;
    opacity: 0.9;
  }

  /* ===== SERVICE BLOCKS ===== */
  .service-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .service-block.reverse {
    direction: rtl;
  }

  .service-block.reverse > * {
    direction: ltr;
  }

  .service-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.4;
    line-height: 1;
    display: block;
    margin-bottom: 0.5rem;
  }

  .service-content h2 {
    margin-bottom: 0.5rem;
  }

  .service-content .ornament {
    display: block;
    width: 50px;
    height: 2px;
    background: var(--gold);
    margin: 1rem 0 1.5rem;
  }

  .service-content p {
    margin-bottom: 1.5rem;
    color: var(--charcoal-light);
    line-height: 1.7;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .service-features li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--charcoal-light);
  }

  .service-features li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.7rem;
    top: 0.3rem;
  }

  .service-note {
    background: var(--cream-dark);
    padding: 1.25rem;
    border-left: 3px solid var(--gold);
    font-size: 0.95rem;
    margin-top: 1.5rem;
  }

  .service-note strong {
    color: var(--slate-deep);
  }

  /* Service split layout */
  .service-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 1.5rem 0;
  }

  .service-half h4 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--slate-deep);
    margin-bottom: 1rem;
  }

  /* Placeholder visual blocks */
  .placeholder-block {
    width: 100%;
    height: 400px;
    background: linear-gradient(135deg, var(--slate-deep), var(--slate));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(201, 168, 76, 0.2);
  }

  .placeholder-block span {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-light);
    opacity: 0.5;
  }

  /* ===== PACKAGES ===== */
  .package-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(201, 168, 76, 0.2);
    padding: 2.5rem 2rem;
    position: relative;
  }

  .package-card.featured {
    border-color: var(--gold);
    background: rgba(201, 168, 76, 0.1);
  }

  .package-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--slate-deep);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
  }

  .package-card h3 {
    color: var(--gold-light);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .package-desc {
    text-align: center;
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
  }

  .package-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .package-features li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .package-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: bold;
  }

  .package-ideal {
    font-size: 0.85rem;
    font-style: italic;
    text-align: center;
    opacity: 0.7;
    margin: 0;
  }

  /* ===== CTA ===== */
  .cta-section {
    background: var(--cream-dark);
  }

  @media (max-width: 768px) {
    .service-block,
    .service-block.reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      direction: ltr;
    }

    .service-split {
      grid-template-columns: 1fr;
    }

    .placeholder-block {
      height: 250px;
    }
  }
</style>
