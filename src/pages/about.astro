---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us | Verse & Vow" description="Founded by a Recording Arts professor, Verse & Vow brings academic excellence and professional artistry to wedding entertainment, photography, and event services.">
  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container text-center">
      <p class="page-hero-pre">Our Story</p>
      <h1>Where Sound Meets Ceremony</h1>
      <p class="page-hero-sub">
        Professional entertainment and media services, built on a foundation
        of academic excellence and real-world artistry.
      </p>
    </div>
  </section>

  <!-- ===== FOUNDER STORY ===== -->
  <section class="section">
    <div class="container">
      <div class="story-grid">
        <div class="story-content">
          <h2>The Verse & Vow Story</h2>
          <span class="ornament"></span>
          <p>
            Verse & Vow was founded by a professor of Recording Arts & Technology
            who spent years watching wedding vendors treat audio as an afterthought.
            Muddy sound systems. Missed vows. Reception music that distorted at
            any reasonable volume.
          </p>
          <p>
            <em>There had to be a better way.</em>
          </p>
          <p>
            So we built an event company the way a recording studio would —
            where sound quality isn't a luxury, it's the foundation. Where
            the same artist who plays your acoustic ceremony transitions
            seamlessly into DJ mode. Where every microphone, every speaker,
            every mix is handled by someone who actually understands acoustics.
          </p>
          <p>
            Along the way, we added photography, videography, and full event
            coordination — all with the same commitment to craft. The result
            is Verse & Vow: a full-service event agency where academic
            excellence meets real-world artistry.
          </p>
        </div>
        <div class="story-visual placeholder-block">
          <span>Founder</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== THE NAME ===== -->
  <section class="section section-cream">
    <div class="container text-center">
      <div class="section-header">
        <h2>Why "Verse & Vow"?</h2>
        <span class="ornament"></span>
      </div>

      <div class="name-meaning">
        <div class="meaning-card">
          <h3>Verse</h3>
          <p class="meaning-types">
            <span>Musical verse</span>
            <span>•</span>
            <span>Sacred verse</span>
            <span>•</span>
            <span>Poetic verse</span>
          </p>
          <p>
            A verse is a unit of music. It's also a passage of scripture.
            And it's a line of poetry. All three meanings live in our name —
            because we serve celebrations that are musical, sacred, and artful.
          </p>
        </div>
        <div class="meaning-card">
          <h3>Vow</h3>
          <p class="meaning-types">
            <span>Promise</span>
            <span>•</span>
            <span>Commitment</span>
            <span>•</span>
            <span>Dedication</span>
          </p>
          <p>
            A vow is the heart of every ceremony. It's also our commitment
            to you: that every note, every frame, every detail will be
            handled with professional care and personal dedication.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section section-dark">
    <div class="container">
      <div class="section-header">
        <h2>What We Believe</h2>
        <span class="ornament"></span>
        <p>
          These principles guide everything we do.
        </p>
      </div>

      <div class="grid-3 values-grid">
        <div class="value-card">
          <h3>Craft Over Convenience</h3>
          <p>
            We don't cut corners. Every microphone placement, every camera
            angle, every song transition is intentional. This isn't a side
            hustle — it's a craft we've spent years mastering.
          </p>
        </div>

        <div class="value-card">
          <h3>Seamless Integration</h3>
          <p>
            When your entertainment, photography, and coordination come from
            one team, everything works better. No vendor miscommunication.
            No style mismatches. Just seamless execution.
          </p>
        </div>

        <div class="value-card">
          <h3>Cultural Reverence</h3>
          <p>
            Every tradition has its own rhythm. Whether we're capturing a
            Hindu ceremony, a Christian wedding, or a secular celebration,
            we approach each with respect and understanding.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EXPERTISE ===== -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Our Expertise</h2>
        <span class="ornament"></span>
        <p>Professional skills, applied to your celebration.</p>
      </div>

      <div class="grid-4 expertise-grid">
        <div class="expertise-item">
          <span class="expertise-icon">🎓</span>
          <h4>Academic Background</h4>
          <p>Recording Arts & Technology</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">🎸</span>
          <h4>Live Performance</h4>
          <p>Acoustic & DJ Services</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">🎬</span>
          <h4>Media Production</h4>
          <p>Photo, Video & Audio</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">🎚️</span>
          <h4>Sound Engineering</h4>
          <p>Live & Studio Mixing</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">📸</span>
          <h4>Visual Storytelling</h4>
          <p>Cinematic & Documentary</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">🌍</span>
          <h4>Cultural Fluency</h4>
          <p>Multi-tradition Events</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">📋</span>
          <h4>Event Coordination</h4>
          <p>Full-service Planning</p>
        </div>
        <div class="expertise-item">
          <span class="expertise-icon">✨</span>
          <h4>Creative Direction</h4>
          <p>Vision to Reality</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===== SERVICE AREA ===== -->
  <section class="section section-cream">
    <div class="container text-center">
      <div class="section-header">
        <h2>Where We Work</h2>
        <span class="ornament"></span>
      </div>

      <div class="regions">
        <div class="region">
          <h3>Southern California</h3>
          <p>Los Angeles, Orange County, San Diego, Inland Empire</p>
        </div>
        <div class="region">
          <h3>Destination Events</h3>
          <p>Available for travel nationwide and internationally</p>
        </div>
      </div>

      <p class="travel-note">
        Based in Southern California, but we love to travel. If your celebration
        takes us somewhere new, we're ready for the adventure.
      </p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section-dark cta-section">
    <div class="container text-center">
      <h2>Let's Create Together</h2>
      <span class="ornament" style="margin: 1rem auto;"></span>
      <p style="max-width: 600px; margin: 0 auto 2.5rem; font-size: 1.15rem; opacity: 0.9;">
        We'd love to hear about your celebration and show you what's possible
        when professional artistry meets personal care.
      </p>
      <a href="/contact" class="btn btn-primary">Start the Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: clamp(8rem, 15vw, 12rem) 0 clamp(4rem, 8vw, 6rem);
    background: linear-gradient(160deg, var(--slate-deep), var(--slate));
    color: var(--cream);
  }

  .page-hero-pre {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .page-hero-sub {
    font-size: 1.15rem;
    max-width: 550px;
    margin: 0 auto;
    opacity: 0.9;
  }

  /* ===== STORY ===== */
  .story-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .story-content h2 {
    margin-bottom: 0.5rem;
  }

  .story-content .ornament {
    display: block;
    width: 50px;
    height: 2px;
    background: var(--gold);
    margin: 1rem 0 1.5rem;
  }

  .story-content p {
    margin-bottom: 1.25rem;
    color: var(--charcoal-light);
    line-height: 1.7;
  }

  .story-content em {
    color: var(--gold-dark);
    font-style: italic;
    font-size: 1.1rem;
  }

  .placeholder-block {
    width: 100%;
    height: 400px;
    background: linear-gradient(135deg, var(--slate-deep), var(--slate));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(201, 168, 76, 0.2);
  }

  .placeholder-block span {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-light);
    opacity: 0.5;
  }

  /* ===== NAME MEANING ===== */
  .name-meaning {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .meaning-card {
    padding: 2.5rem;
    background: var(--white);
    border: 1px solid rgba(201, 168, 76, 0.2);
  }

  .meaning-card h3 {
    font-size: 2rem;
    color: var(--gold-dark);
    margin-bottom: 0.75rem;
  }

  .meaning-types {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--charcoal-light);
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .meaning-card p:last-child {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--charcoal-light);
    margin: 0;
  }

  /* ===== VALUES ===== */
  .value-card {
    padding: 2.5rem 2rem;
    border-left: 3px solid var(--gold);
  }

  .value-card h3 {
    color: var(--gold-light);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .value-card p {
    opacity: 0.85;
    line-height: 1.7;
    font-size: 1rem;
  }

  /* ===== EXPERTISE GRID ===== */
  .expertise-item {
    text-align: center;
    padding: 1.5rem 1rem;
    border: 1px solid rgba(201, 168, 76, 0.15);
    background: var(--white);
    transition: all var(--transition-smooth);
  }

  .expertise-item:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .expertise-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .expertise-item h4 {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate-deep);
    margin-bottom: 0.25rem;
  }

  .expertise-item p {
    font-size: 0.9rem;
    color: var(--charcoal-light);
    margin: 0;
  }

  /* ===== REGIONS ===== */
  .regions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    margin: 2rem auto;
    max-width: 700px;
  }

  .region h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .region p {
    font-size: 0.95rem;
    color: var(--charcoal-light);
    margin: 0 auto;
  }

  .travel-note {
    font-style: italic;
    color: var(--charcoal-light);
    margin-top: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== CTA ===== */
  .cta-section h2 {
    color: var(--gold-light);
  }

  @media (max-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .name-meaning {
      grid-template-columns: 1fr;
    }

    .placeholder-block {
      height: 250px;
    }
  }
</style>
